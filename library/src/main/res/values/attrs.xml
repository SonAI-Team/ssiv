<?xml version="1.0" encoding="utf-8"?>
<resources>

    <declare-styleable name="SubsamplingScaleImageView">
        <attr name="src" format="reference" />
        <attr name="assetName" format="string" />
        <attr name="panEnabled" format="boolean" />
        <attr name="zoomEnabled" format="boolean" />
        <attr name="quickScaleEnabled" format="boolean" />
        <attr name="tileBackgroundColor" format="color" />
        <attr name="doubleTapZoomStyle">
            <enum name="zoomFocusFixed" value="1" />
            <enum name="zoomFocusCenter" value="2" />
            <enum name="zoomFocusCenterImmediate" value="3" />
        </attr>
        <attr name="restoreStrategy">
            <enum name="deferred" value="1" />
            <enum name="immediate" value="2" />
        </attr>
    </declare-styleable>

</resources>
